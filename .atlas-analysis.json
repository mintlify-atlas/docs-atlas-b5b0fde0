  "keyFeatures": [
    "Newsletter and campaign management with rich text editor",
    "Subscriber management with custom attributes and segmentation",
    "List management with single and double opt-in support",
    "HTML template system with Go templating engine",
    "Bounce handling via webhooks and POP3 mailboxes",
    "Transactional email API",
    "Analytics dashboard with campaign views and click tracking",
    "Media library and file management",
    "Role-based access control and permissions",
    "Multi-messenger support (SMTP, SMS, FCM)",
    "OIDC authentication integration",
    "Import/export functionality",
    "Public subscription pages and campaign archives",
    "Multi-language support (i18n)"
  ],
